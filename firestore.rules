rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isLeagueMember(leagueId) {
      return exists(
        /databases/$(database)/documents/memberships/$(leagueId + '_' + request.auth.uid)
      );
    }

    function isLeagueOwner(leagueId) {
      return exists(/databases/$(database)/documents/leagues/$(leagueId))
        && get(/databases/$(database)/documents/leagues/$(leagueId)).data.ownerId == request.auth.uid;
    }

    function isLeagueAdmin(leagueId) {
      return isLeagueMember(leagueId)
        && get(/databases/$(database)/documents/memberships/$(leagueId + '_' + request.auth.uid)).data.role == 'admin';
    }

    function isLeagueAdminOrOwner(leagueId) {
      return isLeagueOwner(leagueId) || isLeagueAdmin(leagueId);
    }

    match /users/{uid} {
      allow read: if signedIn();

      // First sign-in creates the doc with starting ELO.
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.globalElo == 1000
        && request.resource.data.globalWins == 0
        && request.resource.data.globalLosses == 0;

      // Own user can update their profile; other signed-in users can only touch ELO/W/L
      // (this is how recordGame updates the opposite player's global rating).
      allow update: if signedIn() && (
        request.auth.uid == uid
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['globalElo', 'globalWins', 'globalLosses'])
      );

      allow delete: if false;
    }

    match /leagues/{leagueId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;

      // Owner and admins can edit league details; ownerId is immutable.
      allow update: if signedIn()
        && isLeagueAdminOrOwner(leagueId)
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if signedIn()
        && isLeagueOwner(leagueId);
    }

    match /memberships/{membershipId} {
      allow read: if signedIn();

      // Composite ID enforces uniqueness and prevents impersonation.
      // New membership must start at initial rating. Role must be absent or 'member'
      // (admin role is only assigned by owner via a subsequent update).
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && membershipId == request.resource.data.leagueId + '_' + request.auth.uid
        && request.resource.data.leagueElo == 1000
        && request.resource.data.leagueWins == 0
        && request.resource.data.leagueLosses == 0
        && (!('role' in request.resource.data) || request.resource.data.role == 'member');

      // Any member of the league can update ELO/W/L fields (for recordGame).
      allow update: if signedIn()
        && isLeagueMember(resource.data.leagueId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['leagueElo', 'leagueWins', 'leagueLosses']);

      // Only the league owner can change a member's role.
      allow update: if signedIn()
        && isLeagueOwner(resource.data.leagueId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['role'])
        && (!('role' in request.resource.data) || request.resource.data.role in ['admin', 'member']);

      // Own membership (leave) or admin/owner (kick).
      allow delete: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isLeagueAdminOrOwner(resource.data.leagueId)
      );
    }

    match /games/{gameId} {
      allow read: if signedIn();

      // Caller must be in the league; both players must also be members.
      allow create: if signedIn()
        && isLeagueMember(request.resource.data.leagueId)
        && exists(/databases/$(database)/documents/memberships/$(request.resource.data.leagueId + '_' + request.resource.data.winnerId))
        && exists(/databases/$(database)/documents/memberships/$(request.resource.data.leagueId + '_' + request.resource.data.loserId));

      // Immutable for now — Phase 10 opens update for ELO recompute.
      allow update: if false;

      // League admin/owner can delete (needed for cascade on league delete).
      // Phase 10 expands this to winner/loser of the game.
      allow delete: if signedIn() && isLeagueAdminOrOwner(resource.data.leagueId);
    }
  }
}
